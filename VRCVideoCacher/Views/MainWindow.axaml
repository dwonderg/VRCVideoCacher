<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VRCVideoCacher.ViewModels"
        xmlns:views="using:VRCVideoCacher.Views"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:loc="using:CodingSeb.Localization.Avalonia"
        xmlns:viewModels="clr-namespace:VRCVideoCacher.ViewModels"
        x:Class="VRCVideoCacher.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Title="{Binding Title}"
        Icon="avares://VRCVideoCacher/Assets/icon.ico"
        Width="1000" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- Update Banner -->
        <Border Grid.Row="0" Background="#2d7d46" Padding="10,8"
                IsVisible="{Binding IsUpdateAvailable}">
            <Grid ColumnDefinitions="*, Auto, Auto">
                <TextBlock Grid.Column="0" Text="{Binding UpdateVersionText}"
                           VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                <Button Grid.Column="1" Content="Update Now" Margin="10,0"
                        Command="{Binding ApplyUpdateCommand}"
                        Background="#1b5e30" Foreground="White" Padding="12,4"/>
                <Button Grid.Column="2" Content="Dismiss"
                        Command="{Binding DismissUpdateCommand}"
                        Background="Transparent" Foreground="White" Padding="8,4"/>
            </Grid>
        </Border>

        <!-- DNS Flush Banner -->
        <Border Grid.Row="0" Background="#c62828" Padding="10,8"
                IsVisible="{Binding IsDnsFlushPromptVisible}"
                Margin="0,0,0,0">
            <Grid ColumnDefinitions="*, Auto, Auto">
                <TextBlock Grid.Column="0"
                           Text="A connection failure was detected last session. Flushing your DNS cache may fix video playback issues."
                           VerticalAlignment="Center" Foreground="White" FontWeight="Bold" TextWrapping="Wrap"/>
                <Button Grid.Column="1" Content="Flush DNS Cache" Margin="10,0"
                        Command="{Binding FlushDnsCommand}"
                        Background="#8e0000" Foreground="White" Padding="12,4"/>
                <Button Grid.Column="2" Content="Dismiss"
                        Command="{Binding DismissDnsPromptCommand}"
                        Background="Transparent" Foreground="White" Padding="8,4"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="200, *">
            <!-- Sidebar Navigation -->
            <Border Grid.Column="0" Background="#1a1a1a" Padding="10">
                <StackPanel Spacing="5">
                    <Image Source="avares://VRCVideoCacher/Assets/SmallBanner.png"
                               Margin="0,10,0,20"
                               HorizontalAlignment="Center"/>

                    <Button Command="{Binding NavigateToDashboardCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Classes="nav-button">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <mi:MaterialIcon Kind="ViewDashboard" Width="20" Height="20"/>
                            <TextBlock Text="{loc:Tr Dashboard}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateToHistoryCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Classes="nav-button">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <mi:MaterialIcon Kind="History" Width="20" Height="20"/>
                            <TextBlock Text="{loc:Tr History}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateToCacheBrowserCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Classes="nav-button">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <mi:MaterialIcon Kind="FolderVideo" Width="20" Height="20"/>
                            <TextBlock Text="{loc:Tr CacheBrowser}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateToDownloadQueueCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Classes="nav-button">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <mi:MaterialIcon Kind="Download" Width="20" Height="20"/>
                            <TextBlock Text="{loc:Tr Downloads}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateToSettingsCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Classes="nav-button">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <mi:MaterialIcon Kind="Cog" Width="20" Height="20"/>
                            <TextBlock Text="{loc:Tr Settings}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateToLogViewerCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Classes="nav-button">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <mi:MaterialIcon Kind="TextBox" Width="20" Height="20"/>
                            <TextBlock Text="{loc:Tr Logs}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateToAboutCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Classes="nav-button">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <mi:MaterialIcon Kind="Information" Width="20" Height="20"/>
                            <TextBlock Text="{loc:Tr About}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="10">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                        <views:DashboardView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                        <views:SettingsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:CacheBrowserViewModel}">
                        <views:CacheBrowserView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:DownloadQueueViewModel}">
                        <views:DownloadQueueView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:LogViewerViewModel}">
                        <views:LogViewerView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
                        <views:HistoryView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:AboutViewModel}">
                        <views:AboutView/>
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#252525" Padding="10,5">
            <Grid ColumnDefinitions="*, Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding CacheStatusText}" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>

    <Window.Styles>
        <Style Selector="Button.nav-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style Selector="Button.nav-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#333333"/>
        </Style>
    </Window.Styles>
</Window>
