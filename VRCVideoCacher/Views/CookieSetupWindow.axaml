<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VRCVideoCacher.ViewModels"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:loc="using:CodingSeb.Localization.Avalonia"
        x:Class="VRCVideoCacher.Views.CookieSetupWindow"
        x:DataType="vm:CookieSetupViewModel"
        Title="{loc:Tr CookieSetupTitle}"
        Width="550" Height="480"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="False">

    <Grid RowDefinitions="Auto, *, Auto" Margin="20">
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{loc:Tr CookieSetupTitle}" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{loc:Tr CookieSetupSubtitle}" Foreground="#888888" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Content - Step 1: Browser Selection -->
        <Border Grid.Row="1" Background="#2d2d2d" CornerRadius="8" Padding="20"
                IsVisible="{Binding IsStep1}">
            <StackPanel Spacing="15">
                <TextBlock Text="{loc:Tr CookieSetupStep1Header}" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="{loc:Tr CookieSetupStep1Desc}" TextWrapping="Wrap" Foreground="#cccccc"/>

                <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Command="{Binding SelectChromeCommand}" Width="200" Height="150" Background="#3d3d3d"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <mi:MaterialIcon Kind="GoogleChrome" Width="40" Height="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Tr Chrome}" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Tr ChromeBased}" FontSize="11" Foreground="#888888" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SelectFirefoxCommand}" Width="200" Height="150" Background="#3d3d3d"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <mi:MaterialIcon Kind="Firefox" Width="40" Height="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Tr Firefox}" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Tr FirefoxBased}" FontSize="11" Foreground="#888888" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content - Step 2: Install Extension -->
        <Border Grid.Row="1" Background="#2d2d2d" CornerRadius="8" Padding="20"
                IsVisible="{Binding IsStep2}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Bottom" Text="{loc:Tr CookieSetupStep2AccountWarning}" TextWrapping="Wrap" Foreground="#d4be9d" Margin="0,15,0,0"/>

                <StackPanel Spacing="15">
                    <TextBlock Text="{loc:Tr CookieSetupStep2Header}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="{loc:Tr CookieSetupStep2Desc}" TextWrapping="Wrap" Foreground="#cccccc"/>

                    <Button Command="{Binding OpenExtensionStoreCommand}" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="OpenInNew" Width="16" Height="16"/>
                            <TextBlock Text="{Binding ExtensionStoreButtonText}"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{loc:Tr CookieSetupStep2AfterInstall}" TextWrapping="Wrap" Foreground="#cccccc" Margin="0,10,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content - Step 3: Visit YouTube -->
        <Border Grid.Row="1" Background="#2d2d2d" CornerRadius="8" Padding="20"
                IsVisible="false">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <TextBlock Text="{loc:Tr CookieSetupStep3Header}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="{loc:Tr CookieSetupStep3Desc}" TextWrapping="Wrap" Foreground="#cccccc"/>

                    <Button Command="{Binding OpenYouTubeCommand}" HorizontalAlignment="Center" Margin="0,5,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Youtube" Width="16" Height="16"/>
                            <TextBlock Text="{loc:Tr OpenYouTube}"/>
                        </StackPanel>
                    </Button>

                    <Border Background="#1a1a1a" CornerRadius="4" Padding="12" Margin="0,5,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <mi:MaterialIcon Kind="{Binding CookieStatusIcon}" Width="24" Height="24"
                                            Foreground="{Binding CookieStatusColor}"/>
                            <TextBlock Text="{Binding CookieStatusText}" VerticalAlignment="Center"
                                      Foreground="{Binding CookieStatusColor}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{loc:Tr CookieSetupStep3Note}" TextWrapping="Wrap" Foreground="#888888" FontSize="11" Margin="0,5,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Content - Step 4: Hosts File -->
        <Border Grid.Row="1" Background="#2d2d2d" CornerRadius="8" Padding="20"
                IsVisible="{Binding IsStep4}">
            <StackPanel Spacing="15">
                <TextBlock Text="{loc:Tr CookieSetupStep4Header}" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="{loc:Tr CookieSetupStep4Desc}" TextWrapping="Wrap" Foreground="#cccccc"/>

                <Border Background="#1a1a1a" CornerRadius="4" Padding="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <mi:MaterialIcon Kind="{Binding HostStatusIcon}" Width="24" Height="24"
                                        Foreground="{Binding HostStatusColor}"/>
                        <TextBlock Text="{Binding HostStatusText}" VerticalAlignment="Center"
                                   Foreground="{Binding HostStatusColor}"/>
                    </StackPanel>
                </Border>

                <Button Command="{Binding ToggleHostCommand}" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="ShieldEdit" Width="16" Height="16"/>
                        <TextBlock Text="{Binding HostButtonText}"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="{loc:Tr CookieSetupStep4Note}" TextWrapping="Wrap" Foreground="#888888" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Content - Step 5: Complete -->
        <Border Grid.Row="1" Background="#2d2d2d" CornerRadius="8" Padding="20"
                IsVisible="{Binding IsStep5}">
            <StackPanel Spacing="15" VerticalAlignment="Center" HorizontalAlignment="Center">
                <mi:MaterialIcon Kind="CheckCircle" Width="64" Height="64" Foreground="#81C784" HorizontalAlignment="Center"/>
                <TextBlock Text="{loc:Tr CookieSetupComplete}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="{loc:Tr CookieSetupCompleteDesc}" TextWrapping="Wrap" Foreground="#cccccc" HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Footer Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <CheckBox Content="{loc:Tr DontShowThisAgain}" IsChecked="{Binding DontShowAgainChecked}"
                  VerticalAlignment="Bottom" IsVisible="{Binding IsDontShowAgainCheckboxVisible}" Margin="0,0,20,0" Grid.Column="0"/>
            <StackPanel Grid.Row="2"  Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                <Button Content="{loc:Tr Cancel}" Command="{Binding CancelCommand}" IsVisible="{Binding !IsStep5}"/>
                <Button Content="{loc:Tr Back}" Command="{Binding BackCommand}" IsVisible="{Binding CanGoBack}"/>
                <Button Content="{Binding NextButtonText}" Command="{Binding NextCommand}"
                        IsEnabled="{Binding CanGoNext}" Background="#7B68EE"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
