<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VRCVideoCacher.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:loc="using:CodingSeb.Localization.Avalonia"
             x:Class="VRCVideoCacher.Views.DownloadQueueView"
             x:DataType="vm:DownloadQueueViewModel">

    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" Margin="10">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
            <TextBlock Text="{loc:Tr DownloadQueue}" FontSize="24" FontWeight="Bold"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button Command="{Binding RefreshQueueCommand}" ToolTip.Tip="{loc:Tr Refresh}">
                    <mi:MaterialIcon Kind="Refresh" Width="20" Height="20"/>
                </Button>
                <Button Command="{Binding ClearQueueCommand}" ToolTip.Tip="{loc:Tr ClearQueue}" Background="#CF6679">
                    <mi:MaterialIcon Kind="DeleteSweep" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Current Download -->
        <Border Grid.Row="1" Background="#2d2d2d" CornerRadius="8" Padding="20" Margin="0,0,0,15">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="{loc:Tr CurrentDownload}" FontWeight="SemiBold" FontSize="16"/>
                    <Border Grid.Column="1" Background="#333" CornerRadius="4" Padding="8,4">
                        <TextBlock Text="{Binding CurrentStatus}" FontSize="12" Foreground="#81C784"/>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="Auto, *, Auto" IsVisible="{Binding CurrentDownload, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <mi:MaterialIcon Grid.Column="0" Kind="Download" Width="24" Height="24" Foreground="#64B5F6"/>
                    <StackPanel Grid.Column="1" Margin="15,0">
                        <TextBlock Text="{Binding CurrentDownload.VideoId}" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding CurrentDownload.UrlType}" Foreground="#888888" FontSize="12"/>
                            <TextBlock Text="{Binding CurrentDownload.Format}" Foreground="#888888" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Progress Bar -->
                <ProgressBar Value="{Binding DownloadProgress}" Minimum="0" Maximum="100"
                             Height="6" CornerRadius="3"
                             IsVisible="{Binding IsDownloading}"
                             Foreground="#1a73e8" Background="#444"/>

                <TextBlock Text="{loc:Tr NoActiveDownload}"
                           IsVisible="{Binding CurrentDownload, Converter={x:Static ObjectConverters.IsNull}}"
                           Foreground="#888888"/>
            </StackPanel>
        </Border>

        <!-- Manual Download -->
        <Border Grid.Row="2" Background="#2d2d2d" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel Spacing="8">
                <TextBlock Text="{loc:Tr AddManualDownload}" FontWeight="SemiBold" FontSize="14"/>

                <Grid ColumnDefinitions="*, Auto">
                    <TextBox Grid.Column="0" Text="{Binding ManualUrl}" Watermark="{loc:Tr EnterVideoUrl}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="40" MaxHeight="80"/>
                    <Button Grid.Column="1" Command="{Binding AddManualDownloadCommand}" Margin="10,0,0,0"
                            VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                            <TextBlock Text="{loc:Tr Add}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <TextBlock Text="{Binding StatusMessage}"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Foreground="#81C784" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Queue List -->
        <Border Grid.Row="3" Background="#2d2d2d" CornerRadius="8" Padding="20">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                    <TextBlock Text="{loc:Tr QueuedDownloads}" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Grid.Column="1" Foreground="#888888" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} item(s)">
                                <Binding Path="QueuedDownloads.Count"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding QueuedDownloads}"
                         Background="Transparent"
                         IsVisible="{Binding QueuedDownloads.Count, Converter={x:Static vm:GreaterThanZeroConverter.Instance}}">
                    <ListBox.Styles>
                        <Style Selector="ListBox /template/ ScrollViewer">
                            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DownloadItemViewModel}">
                            <Grid ColumnDefinitions="Auto, *, Auto, Auto" Margin="5">
                                <mi:MaterialIcon Grid.Column="0" Kind="Clock" Width="20" Height="20" Foreground="#888888"/>
                                <StackPanel Grid.Column="1" Margin="15,0">
                                    <TextBlock Text="{Binding VideoId}" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding UrlType}" Foreground="#888888" FontSize="12"/>
                                        <TextBlock Text="{Binding Format}" Foreground="#888888" FontSize="12"/>
                                        <TextBlock Text="{Binding QueuedAt}" Foreground="#666666" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding VideoUrl}" Foreground="#555555" FontSize="11"
                                           VerticalAlignment="Center" MaxWidth="200" TextTrimming="CharacterEllipsis"
                                           Margin="0,0,10,0"/>
                                <Button Grid.Column="3"
                                        Command="{Binding $parent[ListBox].((vm:DownloadQueueViewModel)DataContext).RemoveFromQueueCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="Remove from queue"
                                        Background="Transparent" Padding="4">
                                    <mi:MaterialIcon Kind="Close" Width="16" Height="16" Foreground="#CF6679"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="1"
                           Text="{loc:Tr QueueIsEmpty}"
                           Foreground="#888888"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !QueuedDownloads.Count}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
